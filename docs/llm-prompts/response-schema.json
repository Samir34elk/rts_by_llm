{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["skippable_tests", "confidence"],
  "properties": {
    "skippable_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_class", "test_method", "reason"],
        "properties": {
          "test_class": { "type": "string" },
          "test_method": { "type": "string" },
          "reason": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning_summary": {
      "type": "string",
      "maxLength": 500
    }
  }
}
